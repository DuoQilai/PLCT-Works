[146.391297, "o", "\u001b[?2004h\u001b]0;duoqilai@milkv-megrez-4: ~\u0007\u001b[01;32mduoqilai@milkv-megrez-4\u001b[00m:\u001b[01;34m~\u001b[00m$ "]
